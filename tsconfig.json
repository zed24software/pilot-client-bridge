{
    "ts-node": {},
    "compilerOptions": {
        "lib": [
            "ES2021",
            "ES2021.String"
        ],
        "target": "es6",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./ts-build",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src",
    ],
    "exclude": [
        "node_modules"
    ]
}